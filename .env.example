# Application
APP_NAME=changelens
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32-chars

# Database (PostgreSQL — runs anywhere: local, RDS, Cloud SQL, Azure DB)
DATABASE_URL=postgresql+asyncpg://changelens:changelens@localhost:5432/changelens

# Redis (task queue / caching)
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Webhook HMAC secrets (per source — generate with: openssl rand -hex 32)
WEBHOOK_SECRET_GITHUB_ACTIONS=change-me
WEBHOOK_SECRET_ALERTMANAGER=change-me

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=changelens

# Logging
LOG_LEVEL=DEBUG
